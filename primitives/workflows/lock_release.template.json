{
  "name": "{{HYDRATE:env:displayName}} Lock Release{{HYDRATE:env:workflowNamePostfix}}",
  "nodes": [
    {
      "id": "{{HYDRATE:uuid:lock-rel-trigger}}",
      "name": "Execute Workflow Trigger",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1.1,
      "position": [240, 300],
      "parameters": {
        "inputSource": "passthrough"
      }
    },
    {
      "id": "{{HYDRATE:uuid:lock-rel-code}}",
      "name": "Release Lock",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300],
      "parameters": {
        "language": "javascript",
        "jsCode": "// @n8n-harness:primitive — exempt from pure-function discipline\nconst scope = $json.scope || 'default';\nconst lockKey = `lock-${scope}`;\nconst ownerKey = `lock-owner-${$execution.id}`;\nawait this.helpers.redis.call('DEL', lockKey);\nawait this.helpers.redis.call('DEL', ownerKey);\nreturn [{ json: { released: true, scope } }];\n"
      },
      "credentials": {
        "redis": {
          "id": "{{HYDRATE:env:credentials.redis.id}}",
          "name": "{{HYDRATE:env:credentials.redis.name}}"
        }
      }
    }
  ],
  "connections": {
    "Execute Workflow Trigger": {
      "main": [
        [
          {
            "node": "Release Lock",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
