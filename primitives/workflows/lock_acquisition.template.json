        [{ "node": "Wait Timeout — Stop", "type": "main", "index": 0 }],
        [{ "node": "Retry INCR?", "type": "main", "index": 0 }]
      ]
    },
    "Retry INCR?": {
      "main": [
        [{ "node": "INCR Acquire Attempt", "type": "main", "index": 0 }],
        [{ "node": "Wait Before Poll", "type": "main", "index": 0 }]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
