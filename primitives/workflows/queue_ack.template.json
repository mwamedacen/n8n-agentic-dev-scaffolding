      "main": [[{ "node": "Build Ack Context", "type": "main", "index": 0 }]]
    },
    "Build Ack Context": {
      "main": [[{ "node": "GET Permit Sidecar", "type": "main", "index": 0 }]]
    },
    "GET Permit Sidecar": {
