# n8n-harness root .env — base layer for all environments.
#
# Layering precedence (matches admin._load_env):
#   1. This root .env loads first (defaults).
#   2. .env.<env_name> overlays on top with override=True.
#      For shared keys, env-specific values WIN.
#   3. n8n/environments/<env>.yaml provides non-secret config
#      (URLs, IDs, paths, credential refs).

# Required: live n8n base URL or hostname (e.g. your-tenant.app.n8n.cloud).
N8N_INSTANCE_NAME=your-tenant.app.n8n.cloud

# Required: n8n public-API key (Settings → API in the n8n UI).
N8N_API_KEY=your_api_key_here

# Default LLM provider for `helpers.llm()` and DSPy. OpenRouter is the
# default — n8n-harness no longer assumes OpenAI.
OPENROUTER_API_KEY=your_openrouter_key_here

# Optional alternates for DSPy:
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
