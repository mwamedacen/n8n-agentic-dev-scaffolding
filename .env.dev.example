# n8n-harness dev overlay — copy to .env.dev to override the root .env
# for the `dev` environment only. Env-specific values WIN for shared keys.
#
# Anything you don't set here falls through to the root .env.

# Override the dev n8n instance / API key:
# N8N_INSTANCE_NAME=dev-instance.app.n8n.cloud
# N8N_API_KEY=your_dev_n8n_api_key_here

# Override LLM keys (optional):
# OPENROUTER_API_KEY=your_openrouter_key_here
