{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/auto_tidy.py",
            "timeout": 120,
            "statusMessage": "Tidying workflow positions...",
            "async": true
          }
        ]
      }
    ]
  }
}
