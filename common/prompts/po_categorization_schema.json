{
  "type": "json_schema",
  "name": "po_categorization",
  "schema": {
    "type": "object",
    "properties": {
      "categorized_items": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "po_number": { "type": "string" },
            "category": { "type": "string", "description": "Spend category" },
            "confidence": { "type": "number", "description": "0.0 to 1.0" },
            "flagged": { "type": "boolean" },
            "flag_reason": { "type": "string", "description": "Reason for flagging, empty if not flagged" }
          },
          "required": ["po_number", "category", "confidence", "flagged", "flag_reason"],
          "additionalProperties": false
        }
      },
      "category_totals": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "category": { "type": "string" },
            "total": { "type": "number" }
          },
          "required": ["category", "total"],
          "additionalProperties": false
        },
        "description": "Spend totals by category"
      },
      "flagged_count": { "type": "integer" },
      "recommended_actions": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "required": ["categorized_items", "category_totals", "flagged_count", "recommended_actions"],
    "additionalProperties": false
  },
  "strict": true
}