{
  "type": "json_schema",
  "name": "data_summary",
  "schema": {
    "type": "object",
    "properties": {
      "summary": {
        "type": "string",
        "description": "A 2-3 sentence summary of the data"
      },
      "highlights": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Key highlights or notable findings"
      },
      "metrics": {
        "type": "object",
        "properties": {
          "total": { "type": "number" },
          "count": { "type": "integer" },
          "average": { "type": "number" },
          "topCategory": { "type": "string" }
        },
        "required": ["total", "count", "average", "topCategory"],
        "additionalProperties": false
      }
    },
    "required": ["summary", "highlights", "metrics"],
    "additionalProperties": false
  },
  "strict": true
}